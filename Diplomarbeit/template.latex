% --- Links ---
\usepackage[unicode=true]{hyperref}
\hypersetup{
  colorlinks=true,
  linkcolor=black,
  citecolor=black,
  urlcolor=htlblue,
  pdfauthor={Samaneh Madani, Maria Binder, Negin Sadeghi},
  pdftitle={Diplomarbeit BIS-Ares}
